#!/bin/bash
# /usr/lib/systemd/system-sleep/cec-wake-detector
# Systemd sleep hook - runs immediately on suspend/resume
# Guaranteed execution by systemd, not dependent on signals

SCRIPT_DIR="/home/server/Projects/scripts/cec2"
LOG_FILE="/var/log/cec-wake-detection.log"

log_message() {
    local msg="$1"
    echo "$(date '+%Y-%m-%d %H:%M:%S') [SLEEP-HOOK] $msg" | tee -a "$LOG_FILE"
}

log_message "=== Sleep hook called with args: $* ==="

case "$1" in
    pre)
        log_message "PRE-SUSPEND: System going to sleep - turning off TV"
        "$SCRIPT_DIR/aboutToTurnOff.sh" >> "$LOG_FILE" 2>&1
        log_message "PRE-SUSPEND: aboutToTurnOff.sh completed"
        ;;
    post)
        log_message "POST-RESUME: System woke up - turning on TV (via sleep hook)"
        sleep 2  # Give system a moment to stabilize after wake
        "$SCRIPT_DIR/wakeUp.sh" >> "$LOG_FILE" 2>&1
        log_message "POST-RESUME: wakeUp.sh completed"
        ;;
esac

log_message "Sleep hook finished"
exit 0
